Class {
	#name : 'SPDModel',
	#superclass : 'CMAbstractModel',
	#instVars : [
		'theCells'
	],
	#category : 'SpatializedPrisonersDilemma-Model',
	#package : 'SpatializedPrisonersDilemma-Model'
}

{ #category : 'model - metadata' }
SPDModel class >> aboutThisModel [

	^ '	Here, the famous game theory "Prisoners Dilemma" model is spatialized: each cell (of a Cellular Automata) stands for a player. With a Moore neighbourgood (8), the boundaries are "periodic" (toroidal spatial grid). At each time-step, the strategy of the players being set, each player perform 9 games: with its 8 neighbours and also with itself. The total payoff is then compared to the total payoffs of the 8 neighbours players. If one of them is higher than the personal one, then the corresponding strategy will be adopted for the next time-step.
	For more information, visit [our website](https://cormas.org/models/spd).
'
]

{ #category : 'as yet unclassified' }
SPDModel class >> modelName [

	^ 'SpatializedPrisonersDilemma'
]

{ #category : 'accessing' }
SPDModel class >> prefix [

	^ 'SPD'
]

{ #category : 'model - metadata' }
SPDModel class >> screenshotContents [
	"Screenshot of model's spatial grid provided as a string in Base 64 encoding"

	^ ''
]

{ #category : 'probes' }
SPDModel >> cooperation [

	<probeNamed: 'cooperation rate' color: '0000FF'>
	^ (theCells select: [ :c | c isCooperating ]) size
	  / theCells size
]

{ #category : 'probes' }
SPDModel >> defection [

	<probeNamed: 'defection rate' color: 'FF0000'>
	^ (theCells select: [ :c | c isDefecting ]) size
	  / theCells size
]

{ #category : 'init' }
SPDModel >> init [
	"This method is used to define the initial environment of a simulation. It will be executed once when the simulation is initialized."

	<init>
	self
		createGridNumberOfRows: 61
		numberOfColumns: 61
		neighbourhood: 8
		closed: false.
	self centralCell
		previousState: #defection;
		state: #defection.
	SPDCell setWinningsMatrix.
	theCells := self @@ SPDCell
]

{ #category : 'as yet unclassified' }
SPDModel >> modelName [
	"A human-friendly name of the model"
	^ 'SpatializedPrisonersDilemma'
]

{ #category : 'accessing' }
SPDModel >> prefix [
	"Every class name in model package must begin with this prefix"
	^ 'SPD'.
]

{ #category : 'control' }
SPDModel >> step [
	"This method will be executed at every step of the simulation"

	<control>
	theCells do: [ :a | a setWinnings ]. 
	theCells do: [ :a | a newState ].
	theCells do: [ :a | a updateState ]
]
